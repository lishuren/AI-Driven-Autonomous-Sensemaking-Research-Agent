# ============================================================
#  AI-Driven Autonomous Sensemaking Research Agent — environment variables
# ============================================================
#
# Copy this file to .env and fill in the values you need.
# The agent also accepts search and budget limits as CLI flags —
# CLI flags always take precedence over environment variables.
#
# Usage:
#   cp .env.example .env
#   # edit .env, then from sensemaking-agent/:
#   python -m sensemaking_agent --query "lithium supply chain risks"
#
# Lines starting with # are comments and are ignored.
# ============================================================


# ── Search API ───────────────────────────────────────────────
# Required. Get a free key at https://app.tavily.com
# CLI equivalent: --tavily-key
TAVILY_API_KEY=tvly-YOUR-API-KEY-HERE


# ── LLM Provider ─────────────────────────────────────────────
# Ollama model name or OpenAI-compatible model identifier.
# Default: qwen2.5:7b
#SENSEMAKING_LLM_MODEL=qwen2.5:7b

# Which backend to use: ollama | openai (and OpenAI-compatible aliases like siliconflow).
# Default: ollama
#SENSEMAKING_LLM_PROVIDER=ollama

# Base URL for the LLM server.
# Ollama default: http://localhost:11434
# SiliconFlow:    https://api.siliconflow.cn/v1
#SENSEMAKING_LLM_BASE_URL=http://localhost:11434

# API key for online OpenAI-compatible providers.
# Not required for local Ollama.
#SENSEMAKING_LLM_API_KEY=sk-YOUR-API-KEY-HERE


# ── Prompt Templates ─────────────────────────────────────────
# Directory containing custom .md prompt template overrides.
# Files present here take precedence over the bundled prompts/ directory.
# CLI equivalent: --prompt-dir
#SENSEMAKING_PROMPT_DIR=/path/to/my-prompts


# ── Budget Controls ──────────────────────────────────────────
# Maximum Tavily search or extract API calls per run.
# CLI equivalent: --max-queries
#SENSEMAKING_MAX_QUERIES=50

# Maximum Tavily API credits to spend per run.
# CLI equivalent: --max-credits
#SENSEMAKING_MAX_CREDITS=50.0


# ── Scraping Controls ────────────────────────────────────────
# Disable Playwright fallback scraping entirely.
# CLI equivalent: --no-scrape
#SENSEMAKING_NO_SCRAPE=false

# Enable advisory robots.txt checks before scraping.
# CLI equivalent: --respect-robots / --no-respect-robots
# Default: true
#SENSEMAKING_RESPECT_ROBOTS=true
