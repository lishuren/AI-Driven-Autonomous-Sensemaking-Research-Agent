# ============================================================
#  Topic Example — Legacy .NET C# Maintenance
#  Copy this file to .env and fill in your keys.
# ============================================================

# ── Search API ───────────────────────────────────────────────
# Required. Get a free key at https://app.tavily.com
TAVILY_API_KEY=tvly-YOUR-API-KEY-HERE


# ── LLM Provider ─────────────────────────────────────────────
# Option A — Local Ollama (default)
# Make sure `ollama serve` is running and qwen2.5:7b is pulled.
#SENSEMAKING_LLM_MODEL=qwen2.5:7b
#SENSEMAKING_LLM_PROVIDER=ollama
#SENSEMAKING_LLM_BASE_URL=http://localhost:11434

# Option B — SiliconFlow (online)
#SENSEMAKING_LLM_PROVIDER=openai
#SENSEMAKING_LLM_BASE_URL=https://api.siliconflow.cn/v1
#SENSEMAKING_LLM_API_KEY=sk-YOUR-SILICONFLOW-KEY
#SENSEMAKING_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct


# ── Budget Controls ──────────────────────────────────────────
# Recommended limits for a focused topic like this
SENSEMAKING_MAX_QUERIES=30
SENSEMAKING_MAX_CREDITS=40.0
